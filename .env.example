# =============================================================================
# Central Admin Dashboard — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# Do NOT commit your actual .env file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------

# Port the Express server listens on
PORT=5000

# Environment: development | production | test
NODE_ENV=development

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# MongoDB connection string for the main database (auth, users, dormitory)
MONGO_URI=mongodb://localhost:27017/central-admin-dashboard

# Optional: separate MongoDB URI for the CampusFeedback/Complaint database.
# If omitted, complaints are stored in the same database as MONGO_URI.
COMPLAINT_MONGO_URI=mongodb://localhost:27017/complaint

# Optional: separate MongoDB URI for the Dormitory Reservation database.
# If omitted, the dormitory DB name is appended to the MONGO_URI cluster.
DORMITORY_MONGO_URI=mongodb://localhost:27017/dormitory

# Optional: separate MongoDB URI for the Laundry (laundrypro) database.
# If omitted, the laundrypro DB name is appended to the MONGO_URI cluster.
LAUNDRY_MONGO_URI=mongodb://localhost:27017/laundrypro

# Optional: separate MongoDB URI for the Water Refilling Station database.
# If omitted, the water_refilling DB name is appended to the MONGO_URI cluster.
WATER_MONGO_URI=mongodb://localhost:27017/water_refilling

# NOTE: Minimart uses MONGO_URI automatically (minimart database, same cluster).

# -----------------------------------------------------------------------------
# Authentication — JWT
# -----------------------------------------------------------------------------

# Secret key used to sign access tokens (use a long, random string in production)
JWT_ACCESS_SECRET=your-access-token-secret-here

# Secret key used to sign refresh tokens (must differ from JWT_ACCESS_SECRET)
JWT_REFRESH_SECRET=your-refresh-token-secret-here

# Access token expiry duration (e.g., 15m, 1h)
JWT_ACCESS_EXPIRY=15m

# Refresh token expiry duration (e.g., 7d, 30d)
JWT_REFRESH_EXPIRY=7d

# -----------------------------------------------------------------------------
# Cookies
# -----------------------------------------------------------------------------

# Secret used to sign cookies (use a long, random string in production)
COOKIE_SECRET=your-cookie-secret-here

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------

# Allowed frontend origin for Cross-Origin Resource Sharing
CLIENT_ORIGIN=http://localhost:5173
